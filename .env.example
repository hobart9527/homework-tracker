NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PROJECT_ID=your-project-id

# Optional scheduled job protection
CRON_SECRET=replace-with-a-random-secret

# Telegram parent channel
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token

# Platform credentials encryption (32+ chars recommended)
PLATFORM_CREDENTIALS_ENCRYPTION_KEY=replace-with-a-random-secret-min-32-chars

# Voice push bridge sender endpoint
# For local development with iLink Bridge bundled (recommended):
#   使用 npm run dev:with-bridge 可一键同时启动 Next.js + Bridge，无需另开终端
#   首次运行需要扫码授权，登录态自动缓存到本地
VOICE_PUSH_BRIDGE_URL=http://127.0.0.1:4010/send
VOICE_PUSH_BRIDGE_TOKEN=dev-bridge-token

# iLink Bot protocol endpoints (only needed for real WeChat)
ILINK_API_BASE_URL=https://ilinkai.weixin.qq.com
ILINK_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# Bridge credentials path (optional, defaults to ~/.voice-push-bridge/credentials.json)
# For cloud deployment: set this to a persistent volume path
# CREDENTIALS_PATH=/data/voice-push-bridge/credentials.json

# Bridge auto-sync to wechat_groups table (optional)
# When BRIDGE_PARENT_ID is set, the bridge will automatically upsert discovered
# WeChat groups into the wechat_groups table in Supabase.
# BRIDGE_PARENT_ID=your-parent-uuid

# Supabase service role key (required for generating signed URLs for voice file downloads)
# Also required when BRIDGE_PARENT_ID is set for auto-syncing discovered groups
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
